@model string
@{
    ViewBag.Title = "Login";
}
<div class="container">
    <form id="login-form" asp-action="Login" method="post" asp-route-returnUrl="@Model">
        <label for="login">Login</label>
        <input name="login" id="login"/>
        <label for="password">Password</label>
        <input name="password" type="password" id="password" />
    </form>
    <button type="submit" form="login-form">Login</button>
</div>

<style>
    .container{
        display:flex;
        flex-direction: column;
        gap: 10px;
        width: fit-content;
    }
    #login-form{
        display: grid;
        gap: 5px;
        grid-auto-flow: row;
        grid-template-columns: max-content 1fr;
    }
    login-form label{
        font-size: 20px;
    }
    login-form input{
        padding: 5px 30px;
    }
    .container button{
        margin-left: auto;
        padding: 5px 15px;
    }
</style>