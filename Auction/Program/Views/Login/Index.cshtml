@model string
@{
    ViewBag.Title = "Authentication";
}
<h1 class="auth-header">Authentication</h1>
<h2 class="auth-desc">&bull; Please, log in to your account or create a new one</h2>
<div class="login-options-container">
    <div class="login-option">
        Log In
        <a asp-controller="login" asp-action="login" asp-route-returnUrl="@Model"></a>
    </div>
    <div class="login-option">
        Register
        <a asp-controller="login" asp-action="register" asp-route-returnUrl="@Model"></a>
    </div>
</div>
<style>
    .auth-header{
        text-align: center;
        font-size: 24px;
        margin: 5px 0 0 0;
    }

    .auth-desc {
        text-align: center;
        font-size: 20px;
        color: gray;
        margin: 1px 0;
    }
    .login-options-container{
        display: flex;
        gap: 20px;
        margin: 30px 0;
        padding: 5px 20px;
    }
    .login-option{
        flex: 1 1 0;
        position: relative;
        aspect-ratio: 3/1;
        display: flex;
        background: rgba(255, 255, 255, 1);
        align-items: center;
        justify-content: center;
        border: 1px solid black;
        border-radius: 5px;
        letter-spacing: 2px;
        font-size: 36px;
        font-weight: bold;
        transition: 0.3s ease;
    }
    .login-option:hover {
        background: rgba(200, 200, 240, 1);
    }
    .login-option a {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
    }
</style>