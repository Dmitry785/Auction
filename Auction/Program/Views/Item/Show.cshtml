@model Program.ViewModels.ItemViewModel
@{
    ViewBag.Title = "Item info";
}
<div class="container">
    <div class="item-poster-cont">
        <img src="@Model.Item.Poster">
    </div>
    <div class="item-desc-cont">
        <span>@Model.Item.ItemName</span>
        <span>@Model.Item.ItemType</span>
        <span>@Model.Item.OwnerUsername</span>
        <span>@Model.Item.ItemDescription</span>
    </div>
</div>

<style>
    .container{
        display: flex;
        gap: 20px;
        height: min-content;
    }
    .item-desc-cont{
        flex: 1 1 0;
        gap: 5px;
        display: flex;
        flex-direction: column;
        justify-content: space-around;
    }
    .item-desc-cont span{
        font-size: 20px;
    }
    .item-poster-cont {
        flex: 2 1 0;
        min-width: 0;
        display: flex;
        justify-content: center;
        align-items: center;
    }
    .item-poster-cont img{
        object-fit: contain;
        margin: 20px;
    }
</style>